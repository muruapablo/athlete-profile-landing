# Instagram Basic Display API
# Sigue las instrucciones en INSTAGRAM_SETUP.md para obtener estos valores

# 1. App ID de Instagram (obtenlo en Facebook Developers)
INSTAGRAM_APP_ID=tu_app_id_aqui

# 2. App Secret de Instagram (obtenlo en Facebook Developers)
INSTAGRAM_APP_SECRET=tu_app_secret_aqui

# 3. Access Token (se genera después de que la atleta autorice la app)
# Este token se obtiene automáticamente tras completar el OAuth flow
INSTAGRAM_ACCESS_TOKEN=

# 4. URL de tu sitio (para el callback de OAuth)
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
